# Required
AZURE_SEARCH_SERVICE=https://<your-search-service>.search.windows.net
AZURE_OPENAI_ACCOUNT=https://<your-openai-account>.openai.azure.com/
AZURE_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net

# Required for OCR pipelines (Azure AI Services)
AZURE_AI_SERVICES_KEY=<your-ai-services-key>

# Optional: SharePoint indexing
SHAREPOINT_INDEXER_APP_ID=<app-registration-client-id>
SHAREPOINT_INDEXER_APP_SECRET=<app-registration-secret>
SHAREPOINT_TENANT_ID=<tenant-id>
